#!/bin/bash

set -e

TITLE="chore: add Standard.Site to blog posts"

cd $GITHUB_WORKSPACE

git config --global user.email "github-actions[bot]@users.noreply.github.com"
git config --global user.name "github-actions[bot]"

git remote set-url origin https://x-access-token:${GITHUB_TOKEN}@github.com/${GITHUB_REPOSITORY}.git

BRANCH="chore/blog-to-standard-site"

if git fetch origin $BRANCH 2>/dev/null; then
  git stash
  git checkout --track origin/$BRANCH
  git stash pop
else
  git checkout -b $BRANCH
fi

git add .
git commit -m "$TITLE"
git push origin $BRANCH

EXISTING_PR=$(gh pr list --head $BRANCH --base $GITHUB_REF_NAME --json number -q '.[0].number')

if [ -z "$EXISTING_PR" ]; then
  gh pr create \
    --title "$TITLE" \
    --body "Automated PR to add \`standard_site\` frontmatter field to new blog posts." \
    --base $GITHUB_REF_NAME \
    --head $BRANCH
fi